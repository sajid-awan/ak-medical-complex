#!/bin/sh
# Strip Cursor attribution trailers injected by the IDE/CLI.
MSG_FILE="$1"

if [ ! -f "$MSG_FILE" ]; then
  exit 0
fi

if sed --version >/dev/null 2>&1; then
  sed -i '/cursoragent@cursor\.com/d;/Co-authored-by: Cursor/d;/Made-with: Cursor/d' "$MSG_FILE"
else
  sed -i '' '/cursoragent@cursor\.com/d;/Co-authored-by: Cursor/d;/Made-with: Cursor/d' "$MSG_FILE"
fi
